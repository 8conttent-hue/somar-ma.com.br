---
// About-C: Layout moderno com card de destaque
interface Stat { value: string; label: string; }
interface Props {
  title: string;
  desc: string;
  image: string;
  btnText: string;
  btnLink: string;
  stats: Stat[];
}
const { title, desc, image, btnText, btnLink, stats } = Astro.props;

const milestones = [
  { year: '2021', text: 'Nascemos com a missão de democratizar o acesso à informação de qualidade.' },
  { year: '2022', text: 'Publicamos nossos primeiros 100 posts e conquistamos os primeiros 10 mil leitores.' },
  { year: '2023', text: 'Expandimos nossa equipe e lançamos novas categorias de conteúdo.' },
  { year: '2024', text: 'Superamos 100 mil leitores mensais e nos tornamos referência no nicho.' },
];
---
<section class="py-20 bg-gray-50">
  <div class="max-w-6xl mx-auto px-4">
    <div class="grid md:grid-cols-2 gap-16 items-start">
      <!-- Esquerda: texto + CTA -->
      <div>
        <span class="text-xs font-bold uppercase tracking-widest text-primary mb-4 block">Nossa História</span>
        <h2 class="text-3xl md:text-4xl font-black text-dark mb-6 leading-tight">{title}</h2>
        <p class="text-gray-500 leading-relaxed mb-8">{desc}</p>

        <!-- Stats -->
        <div class="grid grid-cols-3 gap-4 mb-8">
          {stats.map(stat => (
            <div class="bg-white rounded-2xl p-4 text-center shadow-sm border border-gray-100">
              <div class="text-xl font-black text-primary">{stat.value}</div>
              <div class="text-xs text-gray-500 mt-1">{stat.label}</div>
            </div>
          ))}
        </div>

        <a
          href={btnLink}
          class="inline-flex items-center gap-2 px-6 py-3 bg-primary text-white font-bold rounded-xl hover:opacity-90 transition-opacity"
        >
          {btnText}
        </a>
      </div>

      <!-- Direita: Imagem + Timeline -->
      <div class="relative space-y-6">
        <!-- Imagem -->
        {image && (
          <div class="rounded-3xl overflow-hidden aspect-[4/3]">
            <img src={image} alt={title} class="w-full h-full object-cover" loading="lazy" />
          </div>
        )}

        <!-- Timeline compacta -->
        <div class="relative pl-8">
          <div class="absolute left-2 top-0 bottom-0 w-0.5 bg-primary/20"></div>
          <div class="space-y-4">
            {milestones.map(m => (
              <div class="relative">
                <div class="absolute -left-6 top-1.5 w-3 h-3 rounded-full bg-primary border-2 border-white shadow-sm"></div>
                <div class="bg-white rounded-xl p-4 shadow-sm border border-gray-100">
                  <span class="text-xs font-black text-primary uppercase tracking-widest">{m.year}</span>
                  <p class="text-xs text-gray-600 leading-relaxed mt-1">{m.text}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>