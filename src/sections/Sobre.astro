---
// Sobre-H: Dark Immersive Story - Design imersivo e emocional
interface Stat { value: string; label: string; }
interface Props {
  title: string;
  subtitle?: string;
  desc?: string;
  image: string;
  stats: Stat[];
  content?: string;
}
const { title, subtitle, desc, image, stats, content } = Astro.props;
const description = subtitle || desc || '';
---
<section class="py-24 bg-[#0a0a0a] text-white overflow-hidden relative">
  <!-- Interactive Background Glow -->
  <div class="absolute top-0 left-0 w-full h-[1000px] bg-primary/5 rounded-full blur-[200px] -z-0"></div>
  
  <div class="max-w-6xl mx-auto px-4 relative z-10 w-full text-center">
    <div class="max-w-4xl mx-auto mb-20 animate-fade-in">
       <span class="text-primary font-black uppercase tracking-[0.4em] text-[10px] mb-6 block">Nossa Essência</span>
       <h1 class="text-5xl md:text-8xl font-black tracking-tighter leading-none mb-12 uppercase italic">{title}</h1>
       <div class="w-16 h-1 bg-primary mx-auto mb-12"></div>
       <p class="text-xl md:text-3xl font-light text-white/50 italic leading-relaxed">
          "{description}"
       </p>
    </div>

    <!-- Image & Stats Split -->
    <div class="grid lg:grid-cols-12 gap-12 items-center">
       <div class="lg:col-span-7 relative group">
          <div class="aspect-video rounded-[3rem] overflow-hidden border border-white/5 shadow-2xl relative shadow-primary/10">
             <img src={image} class="w-full h-full object-cover grayscale opacity-40 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-1000" alt="Immersive Story Visual" />
             <div class="absolute inset-0 bg-gradient-to-t from-[#0a0a0a] via-transparent to-transparent"></div>
          </div>
          <!-- Floating Info Card -->
          <div class="absolute -bottom-10 -right-10 bg-white/5 backdrop-blur-xl border border-white/10 p-8 rounded-3xl hidden md:block group-hover:-translate-y-4 transition-transform duration-500">
             <div class="text-3xl font-black text-primary mb-2 animate-pulse">{stats[0]?.value}</div>
             <div class="text-[9px] font-black uppercase tracking-widest text-white/40">{stats[0]?.label}</div>
          </div>
       </div>

       <div class="lg:col-span-5 grid grid-cols-2 gap-8">
          {stats.slice(1, 5)?.map(s => (
             <div class="p-8 rounded-3xl border border-white/5 bg-white/2 hover:bg-white/5 transition-all text-left group">
                <div class="text-3xl font-black text-white mb-2 group-hover:text-primary transition-colors">{s.value}</div>
                <div class="text-[10px] font-black uppercase tracking-widest text-white/20 group-hover:text-white transition-colors">{s.label}</div>
             </div>
          ))}
       </div>
    </div>
  </div>
</section>

<style>
  @keyframes fade-in {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in { animation: fade-in 1.2s ease-out; }
</style>