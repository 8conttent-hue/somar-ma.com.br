---
// Header-A: Logo esquerda, nav horizontal, sticky
import siteConfig from '../data/siteConfig.json';
import { getAllPosts } from '../lib/posts';

const { name, menu: baseMenu = [] } = siteConfig;

// Buscar categorias REAIS do banco de dados (SSR)
let realCategories = [];
try {
  const allPosts = await getAllPosts() || [];
  realCategories = [...new Set(allPosts.map(p => p.category))].filter(Boolean);
} catch (e) {
  console.error('[Header-A Category Error]', e);
}

// Injetar categorias reais no item "Blog" do menu
const menu = baseMenu.map((item: any) => {
  if (item.label.toLowerCase() === 'blog' || item.href === '/blog') {
    return {
      ...item,
      children: realCategories.length
        ? realCategories.map(cat => ({
            label: cat,
            href: `/categoria/${cat.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/[^a-z0-9\s-]/g, '').trim().replace(/\s+/g, '-')}`
          }))
        : undefined,
    };
  }
  return item;
});
---
<header class="sticky top-0 z-[100] bg-white border-b border-gray-200 shadow-sm">
  <div class="max-w-6xl mx-auto px-4 flex items-center justify-between h-16">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 font-bold text-xl text-primary hover:opacity-80 transition-opacity">
      <div class="w-8 h-8 bg-primary rounded-lg flex items-center justify-center text-white text-sm font-black">
        {name.charAt(0).toUpperCase()}
      </div>
      {name}
    </a>

    <!-- Nav desktop -->
    <nav class="hidden md:flex items-center gap-6">
      {menu.map((item: any) => (
        item.children?.length ? (
          <div class="relative group h-16 flex items-center">
            <button type="button" class="flex items-center gap-1 text-sm font-medium text-gray-600 group-hover:text-primary transition-colors h-full cursor-pointer">
              {item.label}
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="absolute top-full left-0 z-[110] pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all">
              <div class="w-48 bg-white border border-gray-100 shadow-xl rounded-b-xl py-2">
                <a href={item.href} class="block px-4 py-2 text-xs font-bold text-gray-400 uppercase tracking-widest hover:bg-gray-50 border-b border-gray-50 mb-1">
                  Ver Tudo
                </a>
                {item.children.map((child: any) => (
                  <a
                    href={child.href}
                    class="block px-4 py-2 text-sm text-gray-600 hover:text-primary hover:bg-gray-50 transition-colors"
                  >
                    {child.label}
                  </a>
                ))}
              </div>
            </div>
          </div>
        ) : (
          <a
            href={item.href}
            class="text-sm font-medium text-gray-600 hover:text-primary transition-colors"
          >
            {item.label}
          </a>
        )
      ))}
    </nav>

    <!-- CTA -->
    <a
      href="/blog"
      class="hidden lg:inline-flex items-center px-4 py-2 bg-primary text-white text-sm font-semibold rounded-lg hover:opacity-90 transition-opacity"
    >
      Ver Blog
    </a>

    <!-- Mobile hamburger -->
    <button
      id="menu-btn"
      class="md:hidden p-2 rounded-lg text-gray-600 hover:bg-gray-100"
      aria-label="Menu"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-gray-200 bg-white px-4 py-3 space-y-1">
    {menu.map((item: any) => (
      <div>
        <a
          href={item.href}
          class="block py-2 text-sm font-bold text-gray-900 hover:text-primary"
        >
          {item.label}
        </a>
        {item.children?.length ? (
          <div class="pl-4 border-l-2 border-gray-100 mt-1 space-y-1 mb-2">
            {item.children.map((child: any) => (
              <a
                href={child.href}
                class="block py-2 text-sm text-gray-500 hover:text-primary"
              >
                {child.label}
              </a>
            ))}
          </div>
        ) : null}
      </div>
    ))}
  </div>
</header>

<script>
  const btn = document.getElementById('menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>